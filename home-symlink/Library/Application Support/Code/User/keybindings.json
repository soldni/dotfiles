[
  {
    "command": "composer.toggleBrowserTab",
    "key": "alt+cmd+b"
  },
  {
    "command": "-composer.toggleBrowserTab",
    "key": "shift+cmd+b"
  },
  {
    "command": "workbench.view.scm",
    "key": "ctrl+[ 3"
  },
  {
    "command": "-workbench.view.scm",
    "key": "ctrl+shift+g",
    "when": "workbench.scm.active"
  },
  {
    "command": "workbench.action.tasks.build",
    "key": "ctrl+cmd+b",
    "when": "taskCommandsRegistered"
  },
  {
    "command": "-workbench.action.tasks.build",
    "key": "shift+cmd+b",
    "when": "taskCommandsRegistered"
  },
  {
    "command": "workbench.action.toggleSidebarVisibility",
    "key": "ctrl+[ ["
  },
  {
    "command": "-workbench.action.toggleSidebarVisibility",
    "key": "cmd+b"
  },
  {
    "command": "-claude-vscode.terminal.open.keyboard",
    "key": "cmd+escape",
    "when": "config.claudeCode.useTerminal"
  },
  {
    "command": "-claude-vscode.blur",
    "key": "cmd+escape",
    "when": "!config.claudeCode.useTerminal && !editorTextFocus"
  },
  {
    "command": "-claude-vscode.focus",
    "key": "cmd+escape",
    "when": "editorTextFocus && !config.claudeCode.useTerminal"
  },
  {
    "command": "workbench.action.toggleAuxiliaryBar",
    "key": "ctrl+] ]"
  },
  {
    "command": "-workbench.action.toggleAuxiliaryBar",
    "key": "alt+cmd+b",
    "when": "!isAuxiliaryWindowFocusedContext"
  },
  {
    "command": "workbench.view.explorer",
    "key": "ctrl+[ 1"
  },
  {
    "command": "-workbench.view.explorer",
    "key": "shift+cmd+e",
    "when": "viewContainer.workbench.view.explorer.enabled"
  },
  {
    "command": "workbench.view.search",
    "key": "ctrl+[ 2"
  },
  {
    "command": "-workbench.view.search",
    "key": "shift+cmd+f",
    "when": "workbench.view.search.active && neverMatch =~ /doesNotMatch/"
  },
  {
    "command": "workbench.view.extensions",
    "key": "ctrl+[ 6"
  },
  {
    "command": "-workbench.view.extensions",
    "key": "shift+cmd+x",
    "when": "viewContainer.workbench.view.extensions.enabled"
  },
  {
    "command": "workbench.view.debug",
    "key": "ctrl+[ 4"
  },
  {
    "command": "-workbench.view.debug",
    "key": "shift+cmd+d",
    "when": "viewContainer.workbench.view.debug.enabled"
  },
  {
    "command": "workbench.action.terminal.toggleTerminal",
    "key": "ctrl+] 1"
  },
  {
    "key": "ctrl+] 3",
    "command": "workbench.view.extension.claude-sidebar-secondary"
  },
  {
    "key": "ctrl+] 2",
    "command": "chatgpt.openSidebar"
  },
  {
    "key": "ctrl+shift+cmd+`",
    "command": "workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  },
  {
    "key": "ctrl+shift+`",
    "command": "-workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  },
  {
    "key": "ctrl+shift+`",
    "command": "workbench.action.createTerminalEditor"
  },
  {
    "key": "ctrl+[ 5",
    "command": "workbench.view.remote"
  },
  {
    "key": "ctrl+] 5",
    "command": "workbench.panel.chat",
    "when": "workbench.panel.chat.view.copilot.active"
  },
  {
    "key": "ctrl+cmd+i",
    "command": "-workbench.panel.chat",
    "when": "workbench.panel.chat.view.copilot.active"
  },
  {
    "key": "ctrl+[ 7",
    "command": "workbench.view.extension.todo-tree-container"
  }
]
